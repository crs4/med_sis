[{ "pk": 21, "model": "base.topiccategory", "fields": { "description": "Soil chemical health refers to the balance of nutrients, pH, and organic matter that determines a soil's ability to support plant growth. It relies on key indicators like Soil Organic Carbon (SOC), pH, and Cation Exchange Capacity (CEC) to regulate nutrient availability and neutralize toxins.", "gn_description": "Soil Chemical Health", "is_choice": true, "fa_class": "fa-flask", "identifier": "soil_chemical_health"}},{ "pk": 22, "model": "base.topiccategory", "fields": { "description": "Soil physical health refers to the soil's capacity to support root growth, store and transmit water, and allow adequate aeration. Optimal conditions rely on a balanced texture, strong aggregate stability, and minimal compaction. These traits ensure roots have the necessary space and resources to flourish.", "gn_description": "Soil Physical Health", "is_choice": true, "fa_class": "fa-chart-diagram", "identifier": "soil_physical_health"}},{ "pk": 23, "model": "base.topiccategory", "fields": { "description": "Soil biological health refers to the soil's capacity to function as a living ecosystem. It is driven by billions of microorganisms (bacteria, fungi, and archaea) that decompose organic matter, cycle nutrients (like nitrogen and phosphorus), improve soil structure, and suppress diseases.", "gn_description": "Soil Biological Health", "is_choice": true, "fa_class": "fa-dna", "identifier": "soil_biological_health"}},{ "pk": 24, "model": "base.topiccategory", "fields": { "description": "Soil profiles and soil samples with chemical and physical properties", "gn_description": "Points Soil Data", "is_choice": true, "fa_class": "fa-person-digging", "identifier": "points_soil_data"}}, {"model": "base.hierarchicalkeyword", "pk": 4, "fields": {"name": "Other Maps", "slug": "other_maps", "path": "0005", "depth": 1, "numchild": 11}}, {"model": "base.hierarchicalkeyword", "pk": 5, "fields": {"name": "Agro-ecological zones", "s