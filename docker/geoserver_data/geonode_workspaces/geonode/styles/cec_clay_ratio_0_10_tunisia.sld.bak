<?xml version="1.0" encoding="UTF-8"?>
<StyledLayerDescriptor version="1.0.0" 
 xsi:schemaLocation="http://www.opengis.net/sld StyledLayerDescriptor.xsd" 
 xmlns="http://www.opengis.net/sld" 
 xmlns:ogc="http://www.opengis.net/ogc" 
 xmlns:xlink="http://www.w3.org/1999/xlink" 
 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <!-- a Named Layer is the basic building block of an SLD document -->
  <NamedLayer>
    <Name>default_point</Name>
    <UserStyle>
    <!-- Styles can have names, titles and abstracts -->
      <Title>Red Square Point</Title>
      <Abstract>A sample style that draws a red square point</Abstract>
      <!-- FeatureTypeStyles describe how to render different features -->
      <!-- A FeatureTypeStyle for rendering points -->
      <FeatureTypeStyle>
        <Rule>
          <Name>rule1</Name>
          <Title>Point</Title>
          <Abstract>A 8 pixel circle with a red fill </Abstract>
            <PointSymbolizer>
              <Graphic>
 5           <Mark>
 6             <WellKnownName>circle</WellKnownName>
 7             <Fill>
 8               <CssParameter name="fill">#FFAA00</CssParameter>
 9             </Fill>
10             <Stroke>
11               <CssParameter name="stroke">#990000</CssParameter>
12               <CssParameter name="stroke-width">2</CssParameter>
13             </Stroke>
14           </Mark>
15           <Size>8</Size>
16         </Graphic>
          </PointSymbolizer>
        </Rule>
      </FeatureTypeStyle>
    </UserStyle>
  </NamedLayer>
</StyledLayerDescriptor>