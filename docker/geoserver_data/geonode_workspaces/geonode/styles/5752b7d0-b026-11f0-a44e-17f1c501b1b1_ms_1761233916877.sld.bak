<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<StyledLayerDescriptor version="1.0.0" xsi:schemaLocation="http://www.opengis.net/sld StyledLayerDescriptor.xsd" xmlns="http://www.opengis.net/sld" xmlns:ogc="http://www.opengis.net/ogc" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <NamedLayer>
    <Name>Opaque Raster</Name>
    <UserStyle>
      <Name>Opaque Raster</Name>
      <Title>Opaque Raster</Title>
      <FeatureTypeStyle>
        <Rule>
          <Name/>
          <RasterSymbolizer>
            <Opacity>1</Opacity>
            <ColorMap type="ramp">
              <ColorMapEntry color="#1A9641" quantity="0.0" label="Non sodic soil (0.0)" opacity="1"/>
              <ColorMapEntry color="#A6D96A" quantity="0.0375" label="Non sodic soil (0.0375)" opacity="1"/>
              <ColorMapEntry color="#FFFFC0" quantity="0.075" label="Non sodic soil (0.075)" opacity="1"/>
              <ColorMapEntry color="#FDAE61" quantity="0.1125" label="Non sodic soil (01125)" opacity="1"/>
              <ColorMapEntry color="#D7191C" quantity="0.15" label="Sodic soil (0.15)" opacity="1"/>
            </ColorMap>
          </RasterSymbolizer>
        </Rule>
      </FeatureTypeStyle>
    </UserStyle>
  </NamedLayer>
</StyledLayerDescriptor>